  },

  "TeamPlusSystem": {
    "BaseUrl": "https://teamplus-dev.hospital.internal",
    "SystemSn": "99",
    "ApiKey": "dev-system-api-key"
  },

  "TeamPlusChannels": {
    "a": {
      "ChannelId": "dev-channel-a",
      "ChannelSecret": "dev-channel-secret-a",
      "AccessToken": "dev-access-token-a"
    }
  },

  "Security": {
    "HisAllowedIPs": [
      "127.0.0.1",
      "::1",
      "0.0.0.0/0"
    ],
    "AreaWhitelist": {
